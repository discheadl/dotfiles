{
  // ==============================
  // CONFIGURACIأ“N GENERAL
  // ==============================
  "layer": "top",
  "position": "top",
  "exclusive": true,
  //"height": 36,
  "margin-top": 6,
  "margin-left": 15,
  "margin-right": 15,
  "modules-left": [
    "custom/arch",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "group/hardware",
    "group/notifications"
  ],
  "group/hardware": {
    "orientation": "horizontal",
    "modules": [
      //"idle_inhibitor",
      "pulseaudio",
      "pulseaudio#microphone",
      "network",
      "battery"
    ]
  },
  "group/notifications": {
    "orientation": "horizontal",
    "modules": [
      "custom/notifications"
    ]
  },
  // ==============================
  // IZQUIERDA â€“ LOGO ARCH
  // ==============================
  "custom/arch": {
    "format": "ïŒƒ",
    "on-click": "wlogout",
    "tooltip-format": "Menأ؛ de Apagado",
    "tooltip": true
  },
  "clock": {
    "format": "{:%d%b %H:%M}",
    "tooltip-format": "{:%A %d %B %Y}"
  },
  // ==============================
  // CENTRO â€“ WORKSPACES (DOTS)
  // ==============================
  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "all-outputs": true,
    "disable-scroll": true
  },
  // ==============================
  // DERECHA â€“ TRAY
  // ==============================
  "tray": {
    "icon-size": 20,
    "spacing": 10,
    "layer": "overlay",
    "show-passive-items": true
  },
  // ==============================
  // NETWORK
  // ==============================
  "network": {
    "format-wifi": "ï‡«",
    "format-ethernet": "َ°ˆ€",
    "format-disconnected": "َ°–ھ",
    "tooltip": true
  },
  // ==============================
  // AUDIO
  // ==============================
  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "َ°‌ں",
    "format-icons": {
      "default": [
        "َ°•؟",
        "َ°–€",
        "َ°•¾"
      ]
    },
    "scroll-step": 5
  },
  // ==============================
  // BATERأچA
  // ==============================
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    // AQUأچ ESTأپ EL CAMBIO: Agregamos {capacity}% antes del icono
    "format": "{capacity}{icon}",
    "format-charging": "{capacity}َ°‚„",
    "format-plugged": "{capacity}",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "َ°‚ژ",
      "َ°پ؛",
      "َ°پ»",
      "َ°پ¼",
      "َ°پ½",
      "َ°پ¾",
      "َ°پ؟",
      "َ°‚€",
      "َ°‚پ",
      "َ°‚‚",
      "َ°پ¹"
    ],
    "tooltip": true
  },
  // ==============================
  // MICROFONO
  // ==============================
  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "ï„°",
    "format-source-muted": "ï„±",
    "on-click": "pavucontrol -t 4",
    "on-click-middle": "pamixer --default-source -m",
    "scroll-step": 5,
    "tooltip": true,
    "tooltip-format": "Micrأ³fono: {volume}%"
  },
  // ==============================
  // NOTIFICACIONES
  // ==============================
  "custom/notifications": {
    "tooltip": false,
    "format": "َ°‚ڑ",
    "on-click": "bash ~/.config/quickshell/top-bar/toggle-hub.sh",
    "escape": true
  }
}