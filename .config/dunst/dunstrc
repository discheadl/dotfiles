[global]
    # --- MAIN ---
    monitor = 0
    follow = mouse
    script = ~/.config/dunst/alert.sh

    # --- Geometry ---
    width = 300
    height = 440
    origin = top-right
    offset = 12x12
    notification_limit = 5

    # --- Look & Feel ---
    font = Inter 10
    markup = full
    format = "<b>%s</b>\n%b"
    
    # --- Progress Bar ---
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 280
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4
    
    # --- Borders & Padding ---
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 16
    gap_size = 10
    frame_width = 0
    corner_radius = 10
    
    # --- Icons ---
    icon_position = left
    max_icon_size = 48
    icon_path = /usr/share/icons/Papirus-Dark/48x48/status/:/usr/share/icons/Papirus-Dark/48x48/devices/:/usr/share/icons/Papirus-Dark/48x48/apps/
    
    # --- Interaction ---
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/firefox -new-tab
    mouse_left_click = close_current
    mouse_middle_click = close_all
    mouse_right_click = do_action
    
    # --- History ---
    history_length = 100
    sticky_history = yes

    # --- Global Colors ---
    separator_color = frame

[urgency_low]
    background = "#141719"
    foreground = "#fdf6e3"
    frame_color = "#3b4c3a"
    highlight = "#859289"
    timeout = 3

[urgency_normal]
    background = "#141719"
    foreground = "#e5dfc5"
    frame_color = "#141719C8"
    highlight = "#a7c080"
    timeout = 5

[urgency_critical]
    background = "#bd696b"
    foreground = "#272e33"
    frame_color = "#e67e80"
    highlight = "#ffffff"
    timeout = 0

# --- RULES ---
[media_fix]
    summary = "*media*"
    timeout = 2